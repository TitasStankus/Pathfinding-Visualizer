<Window x:Class="Pathfinding_Visualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pathfinding_Visualizer"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="900">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal"
                Margin="10">

            <TextBox
            x:Name="GridSizeInput"
            Width="100"
            Text="20"/>

            <Button
            Content="Create Grid"
            Click="GenerateGrid_Click"
            Margin="10,0,0,0"/>

            <Button
            Content="Reset Path"
            Click="ResetPath_Click"
            Margin="10,0,0,0"/>

        </StackPanel>


        <UniformGrid
        Grid.Row="1"
        x:Name="GridContainer"
        Margin="10"/>

    </Grid>
</Window>
